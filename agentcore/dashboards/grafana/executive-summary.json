{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Agent Runs",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(agentcore_agent_runs_total)",
          "legendFormat": "Total Runs"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Success Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * sum(agentcore_agent_runs_total{status=\"success\"}) / clamp_min(sum(agentcore_agent_runs_total), 1)",
          "legendFormat": "Success %"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total LLM Tokens",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(agentcore_llm_tokens_total)",
          "legendFormat": "Tokens"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "red", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Errors",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(agentcore_errors_total) or vector(0)",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Agent Runs Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(agentcore_agent_runs_total{status=\"success\"}[5m])) * 300",
          "legendFormat": "Success"
        },
        {
          "expr": "sum(rate(agentcore_agent_runs_total{status=\"error\"}[5m])) * 300",
          "legendFormat": "Error"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 * (sum(rate(agentcore_errors_total[5m])) or vector(0)) / clamp_min(sum(rate(http_server_requests_total[5m])), 0.001)",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 7,
      "options": { "orientation": "horizontal" },
      "title": "Top Agents by Run Count",
      "type": "bargauge",
      "targets": [
        {
          "expr": "topk(10, sum by (agent_name) (agentcore_agent_runs_total))",
          "legendFormat": "{{agent_name}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentcore", "executive"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AgentCore - Executive Summary",
  "uid": "agentcore-executive-summary",
  "version": 1
}
