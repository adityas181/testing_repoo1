{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg HTTP Latency",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_ms_milliseconds_sum[5m])) / clamp_min(sum(rate(http_server_request_duration_ms_milliseconds_count[5m])), 0.001)",
          "legendFormat": "Avg Latency"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "noValue": "0",
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "HTTP 5xx Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(agentcore_api_errors_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_total[5m])), 0.001)",
          "legendFormat": "5xx Rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Request Throughput",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Sessions",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(agentcore_active_sessions)",
          "legendFormat": "Sessions"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "HTTP Request Rate by Status Code",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (status_code) (rate(http_server_requests_total[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "HTTP Latency by Route (P95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (route, le) (rate(http_server_request_duration_ms_milliseconds_bucket[5m]))))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Component Build Rate (Success vs Error)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (status) (rate(agentcore_component_builds_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Component Build Duration by Type (P95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (component_type, le) (rate(agentcore_component_build_duration_ms_milliseconds_bucket[5m])))",
          "legendFormat": "{{component_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Errors by Component",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (component) (rate(agentcore_errors_total[5m]))",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Login Attempts (Success vs Failure)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (status) (rate(agentcore_login_attempts_total[5m])) * 300",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentcore", "infrastructure"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AgentCore - Infrastructure Health",
  "uid": "agentcore-infrastructure-health",
  "version": 1
}
