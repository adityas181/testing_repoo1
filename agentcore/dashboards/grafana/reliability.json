{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Errors by Type",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (error_type) (rate(agentcore_errors_total[5m]))",
          "legendFormat": "{{error_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "HTTP 4xx vs 5xx Errors",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(agentcore_api_errors_total{status_code=~\"4..\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(agentcore_api_errors_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Sessions",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(agentcore_active_sessions)",
          "legendFormat": "Sessions"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "id": 4,
      "title": "Component Errors by Type",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (component_type) (rate(agentcore_component_builds_total{status=\"error\"}[5m]))",
          "legendFormat": "{{component_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "title": "API Errors by Route",
      "type": "timeseries",
      "targets": [
        {
          "expr": "topk(10, sum by (route) (rate(agentcore_api_errors_total[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
